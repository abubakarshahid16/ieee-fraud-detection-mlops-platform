{
  "title": "System Health Dashboard",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Latency",
      "targets": [
        {
          "expr": "rate(fraud_api_request_latency_seconds_sum[5m]) / rate(fraud_api_request_latency_seconds_count[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Throughput",
      "targets": [
        {
          "expr": "sum(rate(fraud_api_requests_total[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Resource Usage",
      "targets": [
        {
          "expr": "container_memory_usage_bytes"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
